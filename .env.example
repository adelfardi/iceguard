# Copy to `.env` and fill in. NEVER commit `.env` (it is git-ignored).
#
# Apache Polaris needs real AWS S3 credentials for table writes (MinIO is read-only for
# Polaris — see CLAUDE.md). The REST Catalog and Nessie work on MinIO with no extra creds.
#
# Temporary STS credentials expire (~1h); long-lived IAM keys (or an AssumeRole) avoid that.
POLARIS_AWS_ACCESS_KEY_ID=
POLARIS_AWS_SECRET_ACCESS_KEY=
POLARIS_AWS_SESSION_TOKEN=

# Polaris S3 location + region used by the seed script (scripts/seed-catalog.sh)
POLARIS_S3_LOCATION=s3://your-bucket/warehouse
POLARIS_S3_REGION=us-east-1
